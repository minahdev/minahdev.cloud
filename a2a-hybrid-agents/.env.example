# Cloudflare tunnel base URL the AWS orchestrator uses to reach on-prem.
ONPREM_TUNNEL_URL=https://your-tunnel.example.com

# Ollama models (Q4 tags). Qwen MUST stay 1.5B (4GB VRAM hard limit).
EXAONE_MODEL=exaone3.5:2.4b
QWEN_MODEL=qwen2.5:1.5b
OLLAMA_HOST=http://localhost:11434

# Kùzu embedded graph DB directory.
KUZU_DB_PATH=./data/graph

# Ports.
EXAONE_PORT=8001
QWEN_PORT=8002
ORCH_PORT=8000
